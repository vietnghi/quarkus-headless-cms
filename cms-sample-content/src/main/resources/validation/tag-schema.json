{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://example.com/schemas/tag.json",
  "title": "Tag",
  "description": "Schema for validating Tag content entries",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "maxLength": 100,
      "description": "Tag name (required, unique)"
    },
    "slug": {
      "type": "string",
      "maxLength": 120,
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "description": "URL-friendly slug"
    },
    "color": {
      "type": "string",
      "pattern": "^#[0-9a-fA-F]{6}$",
      "default": "#6b7280",
      "description": "Hex color for tag badge"
    }
  },
  "required": ["name", "slug"],
  "additionalProperties": true
}
