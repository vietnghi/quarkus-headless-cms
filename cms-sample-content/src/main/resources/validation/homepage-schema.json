{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://example.com/schemas/homepage.json",
  "title": "Homepage",
  "description": "Schema for validating Homepage single-type entries",
  "type": "object",
  "properties": {
    "heroTitle": {
      "type": "string",
      "maxLength": 200,
      "description": "Main hero banner title (required)"
    },
    "heroSubtitle": {
      "type": "string",
      "maxLength": 300,
      "description": "Hero banner subtitle"
    },
    "heroCtaText": {
      "type": "string",
      "maxLength": 50,
      "description": "Call-to-action button text"
    },
    "heroCtaUrl": {
      "type": "string",
      "maxLength": 500,
      "description": "Call-to-action link URL"
    },
    "heroImage": {
      "type": "string",
      "description": "Hero background image URL"
    },
    "aboutTitle": {
      "type": "string",
      "maxLength": 200
    },
    "aboutText": {
      "type": "string",
      "description": "About section content (rich text)"
    },
    "featuredArticleIds": {
      "type": "array",
      "items": { "type": "string" },
      "description": "List of featured article document IDs"
    }
  },
  "required": ["heroTitle"],
  "additionalProperties": true
}
