{
    "uid": "api::category.category",
    "kind": "COLLECTION_TYPE",
    "singularName": "category",
    "pluralName": "categories",
    "displayName": "Category",
    "description": "Content categorization taxonomy",
    "draftAndPublish": false,
    "localized": false,
    "fields": [
        {
            "name": "name",
            "type": "STRING",
            "required": true,
            "maxLength": 200
        },
        {
            "name": "slug",
            "type": "UID",
            "required": true,
            "maxLength": 255
        },
        {
            "name": "description",
            "type": "TEXT"
        }
    ],
    "relations": [
        {
            "fieldName": "articles",
            "type": "MANY_TO_MANY",
            "target": "api::article.article",
            "targetAttribute": "categories"
        }
    ]
}
